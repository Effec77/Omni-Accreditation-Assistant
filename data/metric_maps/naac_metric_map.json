      "4.1.2": {
        "name": "Infrastructure Expenditure",
        "criterion": "4",
        "criterion_name": "Infrastructure and Learning Resources",
        "max_points": 100,
        "type": "QnM",
        "formula": "Percentage of budget spent on infrastructure excluding salary last 5 years",
        "scoring_rubric": {
          "100": {"description": ">=15% of total budget on infrastructure", "threshold": {"infrastructure_budget_percentage": 15}},
          "75":  {"description": "10-15% on infrastructure",                "threshold": {"infrastructure_budget_percentage": 10}},
          "50":  {"description": "6-10% on infrastructure",                 "threshold": {"infrastructure_budget_percentage": 6}},
          "25":  {"description": "3-6% on infrastructure",                  "threshold": {"infrastructure_budget_percentage": 3}},
          "0":   {"description": "<3% on infrastructure",                   "threshold": {"infrastructure_budget_percentage": 0}}
        },
        "data_fields_required": ["total_budget", "infrastructure_expenditure", "expenditure_percentage", "year_wise_data"],
        "evidence_keywords": ["infrastructure", "capital expenditure", "construction", "equipment", "laboratory", "budget"]
      },
      "5.1.1": {
        "name": "Students Benefited by Scholarships",
        "criterion": "5",
        "criterion_name": "Student Support and Progression",
        "max_points": 100,
        "type": "QnM",
        "formula": "Percentage of students receiving scholarships or freeships last 5 years",
        "scoring_rubric": {
          "100": {"description": ">=40% students receive scholarships", "threshold": {"scholarship_percentage": 40}},
          "75":  {"description": "25-40% students receive scholarships", "threshold": {"scholarship_percentage": 25}},
          "50":  {"description": "15-25% students receive scholarships", "threshold": {"scholarship_percentage": 15}},
          "25":  {"description": "5-15% students receive scholarships",  "threshold": {"scholarship_percentage": 5}},
          "0":   {"description": "<5% students receive scholarships",    "threshold": {"scholarship_percentage": 0}}
