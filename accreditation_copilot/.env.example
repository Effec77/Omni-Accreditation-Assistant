# Groq API Keys (Multi-key pool for load balancing)
# Get your keys from: https://console.groq.com/keys
GROQ_API_KEY_1=your_groq_key_1_here
GROQ_API_KEY_2=your_groq_key_2_here
GROQ_API_KEY_3=your_groq_key_3_here
GROQ_API_KEY_4=your_groq_key_4_here
GROQ_API_KEY_5=your_groq_key_5_here
GROQ_API_KEY_6=your_groq_key_6_here
GROQ_API_KEY_7=your_groq_key_7_here
# Add up to GROQ_API_KEY_9 for maximum capacity

# Gemini API Key (For chatbot and additional AI features)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# LangSmith API Key (For observability - optional)
# Get your key from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=omni-accreditation-copilot

# HuggingFace Token (Optional - for model downloads)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Ollama Configuration (Local LLM fallback)
OLLAMA_HOST=http://localhost:11434
